# AgentOS Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# LLM Access via OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Direct Anthropic API (optional — OpenRouter covers this)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Perplexity for live web search (via OpenRouter or direct)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# GitHub (for auto-push via stop hook)
GITHUB_TOKEN=your_github_fine_grained_token_here

# Obsidian vault path (used by memory hooks)
OBSIDIAN_VAULT_PATH=C:\Users\navka\navakanth001\obsidian-vault

# Deployment
VERCEL_TOKEN=your_vercel_token_here
NETLIFY_TOKEN=your_netlify_token_here
