# .env.example - Environment Template for Agent OS Cloud Deployment
# Copy this file to .env and fill in the values before launching the service.

# ── 1. SERVER CONFIGURATION ──────────────────────────────────────────────────
# Set to 0.0.0.0 in Docker/Production to allow external bindings
AGENT_OS_HOST=0.0.0.0
AGENT_OS_PORT=8765

# The security key required by clients via the X-API-Key header (SHA-256 equivalent)
AGENT_OS_API_KEY=e84c2337a06d5d5f46406911060bdae59f41ce2c6e276ce87de502ff34526f8b

# Optional: Restricted read-only API key for sharing the dashboard securely
AGENT_OS_REVIEW_KEY=agent-os-review

# ── 2. EXTERNAL SERVICES & API KEYS ──────────────────────────────────────────
# Required for autonomous swarms and goal execution
# (OpenRouter API key for LLM services)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional native Google Gemini key — used as a fallback when OpenRouter is
# rate-limited (429) or out of credits (402).
# GEMINI_API_KEY=your_gemini_api_key_here

# ── 2b. OFFLINE / LOCAL BACKEND (Ollama) ─────────────────────────────────────
# Lets the swarm + goal runner work with ZERO internet and ZERO API keys.
# Used automatically as the primary backend when no cloud key is set, and as the
# last-resort fallback when every cloud path fails (e.g. OpenRouter 402/429).
# Setup:  install https://ollama.com  ->  `ollama pull llama3.2`  ->  `ollama serve`
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── 2c. GOAL-RUNNER MODEL ROUTING ────────────────────────────────────────────
# Defaults are free-tier models so the goal runner doesn't burn OpenRouter
# credits (paid models return 402 Payment Required when credits run out).
# Override with any OpenRouter model id. Ignored when running offline (Ollama).
GOAL_MODEL=google/gemma-4-31b-it:free
GOAL_PLANNER_MODEL=google/gemma-4-31b-it:free
GOAL_RESEARCH_MODEL=google/gemma-4-31b-it:free

# ── 3. QUANTUM BACKEND INTEGRATION ───────────────────────────────────────────
# IBM Quantum platform token (retrieved from quantum.ibm.com)
IBM_QUANTUM_TOKEN=your_ibm_quantum_api_token_here
QUANTUM_BACKEND_PREFERENCE=local # local / ibm (automatic fallback to local Aer if exhausted)

# ── 4. HYBRID LOCAL BRIDGE ROUTING ────────────────────────────────────────────
# Used by the Cloud VPS to delegate Obsidian/NotebookLM execution to local desktop
# (Uncomment and populate on the Cloud VPS deployment)
# LOCAL_BRIDGE_URL=https://local-bridge.agentos-cloud.net
# LOCAL_BRIDGE_KEY=your_local_bridge_access_api_key

# ── 5. LOCAL FILE SYSTEM PATHS ────────────────────────────────────────────────
# Path to your Obsidian Vault (Local Bridge machine only)
OBSIDIAN_VAULT_PATH=C:/Users/navka/navakanth001/obsidian-vault/Obsidian Vault
